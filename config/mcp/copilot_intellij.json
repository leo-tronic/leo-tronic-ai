{
    "servers": {
        "github": {
            "url": "https://api.githubcopilot.com/mcp/",
            "requestInit": {
                "headers": {
                    "Authorization": "Bearer YOUR_GITHUB_PAT"
                }
            }
        },
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp",
                "--api-key",
                "YOUR_CONTEXT7_API_KEY"
            ]
        },
        "mcp-atlassian": {
            "command": "uvx",
            "args": [
                "mcp-atlassian"
            ]
            // NOTE: IntelliJ does not support an "env" block for stdio servers.
            // Set JIRA_URL, JIRA_USERNAME, JIRA_API_TOKEN, CONFLUENCE_URL,
            // CONFLUENCE_USERNAME, CONFLUENCE_API_TOKEN in your shell environment
            // before launching the IDE, or use ${input:...} prompts if supported.
        },
        "redpanda": {
            "url": "https://docs.redpanda.com/mcp"
        },
        "aws-documentation-mcp-server": {
            "command": "uvx",
            "args": [
                "awslabs.aws-documentation-mcp-server@latest"
            ]
            // NOTE: Set FASTMCP_LOG_LEVEL=ERROR, AWS_DOCUMENTATION_PARTITION=aws,
            // and MCP_USER_AGENT in your shell environment before launching the IDE.
        },
        "lucid-software": {
            "url": "https://mcp.lucid.app/mcp"
        },
        "confluent": {
            "command": "npx",
            "args": [
                "-y",
                "@confluentinc/mcp-confluent",
                "-e",
                "YOUR_CONFLUENT_ENV_PATH"
            ]
        },
        "slack": {
            "url": "https://mcp.slack.com/mcp"
            // NOTE: Slack MCP requires OAuth authentication.
            // IntelliJ may prompt you to authenticate via browser when connecting.
            // If not supported natively, use mcp-remote as a stdio wrapper instead.
        },
        "slack-bot": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-slack"
            ]
            // NOTE: Set SLACK_BOT_TOKEN and SLACK_TEAM_ID (E030L02LZ7E) in your
            // shell environment before launching the IDE.
        },
        "MCP-JFrog": {
            "command": "npm",
            "args": [
                "exec",
                "-y",
                "github:jfrog/mcp-jfrog"
            ]
            // NOTE: Set JFROG_ACCESS_TOKEN and JFROG_URL in your shell environment
            // before launching the IDE.
        },
        "grafana": {
            "command": "uvx",
            "args": [
                "mcp-grafana"
            ]
            // NOTE: Set GRAFANA_URL and GRAFANA_SERVICE_ACCOUNT_TOKEN in your shell
            // environment before launching the IDE.
        },
        "drivewealth-api-accounts-local": {
            "command": "npx",
            "args": [
                "-y",
                "@ivotoby/openapi-mcp-server"
            ]
            // NOTE: Set OPENAPI_SPEC_PATH, API_BASE_URL, BO_USERNAME_DEV, and
            // BO_PASSWORD_DEV in your shell environment before launching the IDE.
            // Example: OPENAPI_SPEC_PATH=/Users/lscarano/repos/OpenAPI/src/AccountsAPI.yaml
            //          API_BASE_URL=http://localhost:9090
        }
    }
}
